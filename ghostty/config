# Fonts
font-family = JetBrainsMono Nerd Font, Hack Nerd Font, monospace
font-family-bold = JetBrainsMono Nerd Font, Hack Nerd Font, monospace
font-family-italic = JetBrainsMono Nerd Font, Hack Nerd Font, monospace
font-family-bold-italic = JetBrainsMono Nerd Font, Hack Nerd Font, monospace
font-size = 14
font-feature = +liga

# Background
alpha-blending = native
background = #1a1b26
background-blur = false
background-opacity = 0.8

# Cursor
cursor-color = #ff99ff

# UI / Behavior
confirm-close-surface = false
gtk-titlebar = false
shell-integration = none
split-divider-color = #3b4261
theme = TokyoNight Night
title = ""
unfocused-split-opacity = 1
window-decoration = false

# Create splits
# keybind = ctrl+space>h=new_split:left
# keybind = ctrl+space>j=new_split:down
# keybind = ctrl+space>k=new_split:up
# keybind = ctrl+space>l=new_split:right

# Navigate splits with Alt
# keybind = ctrl+h=goto_split:left
# keybind = ctrl+j=goto_split:down
# keybind = ctrl+k=goto_split:up
# keybind = ctrl+l=goto_split:right

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll

# Send Shift+Enter as CSI-u so TUIs can distinguish it from Enter.
keybind = shift+enter=csi:13;2u

# Legacy encoding sends Alt+Shift+Enter the same as Alt+Enter; send CSI-u so tmux can match M-S-Enter.
keybind = alt+shift+enter=csi:13;4u
