#!/usr/bin/env bash
# mountUp
# Toggle CIFS mount state for a network share mounted at /mnt/<drive-letter>
# Requires: Kerberos ticket, cifs-utils, and an /etc/fstab entry for the mountpoint

# Detect current user's UID and GID so mounts are writable
MYUID=$(id -u)
MYGID=$(id -g)

# CIFS mount options enabling CRUD access
CIFS_OPTS="sec=krb5,cruid=${MYUID},uid=${MYUID},gid=${MYGID},file_mode=0660,dir_mode=0770"

# Check for kerberos ticket
has_ticket() {
  klist &>/dev/null
}

# mount helper
mount_share() {
  local mnt="$1"

  echo "🔍 Checking Kerberos ticket..."
  if ! has_ticket; then
    echo "❌ No Kerberos ticket. Run: kinit AD_USER@AD_REALM"
    exit 1
  fi

  echo "📌 Mounting: $mnt"
  if sudo mount -o "$CIFS_OPTS" "$mnt"; then
    echo "✅ Mounted (CRUD-enabled): $mnt"
  else
    echo "❌ Failed to mount: $mnt"
    exit 1
  fi
}

# unmount helper
unmount_share() {
  local mnt="$1"
  echo "📌 Unmounting: $mnt"
  if sudo umount "$mnt"; then
    echo "✅ Unmounted: $mnt"
  else
    echo "❌ Failed to unmount: $mnt"
    exit 1
  fi
}

toggle_share() {
  local mnt="$1"

  if mount | grep -q "on ${mnt} type cifs"; then
    unmount_share "$mnt"
  else
    mount_share "$mnt"
  fi
}

if [[ $# -ne 1 || ! $1 =~ ^[[:alpha:]]$ ]]; then
  echo "Usage: mountUp [drive-letter]"
  echo
  echo "  mountUp i    Toggle /mnt/i"
  echo "  mountUp h    Toggle /mnt/h"
  echo
  echo "Corresponding CIFS definition in /ets/fstab is required!"
  exit 1
fi

drive=${1,,}
toggle_share "/mnt/${drive}"
