#!/usr/bin/env bash

# ------------------------------------------------------------------------------
# NodeJs HARD reset.
# ------------------------------------------------------------------------------

echo "**********"
echo "Resetting Node.js installation"

if [[ -d /usr/lib/node_modules ]]; then
  echo "Removing /usr/lib/node_modules"
  sudo rm -rf /usr/lib/node_modules
else
  echo "/usr/lib/node_modules does not exist, skipping"
fi

# ------------------------------------------------------------------------------

if command -v apt >/dev/null 2>&1; then
  os_packages=(
    "nodejs"
    "yarn"
  )
  node_packages=(
    "@angular/cli"
    "neovim"
    "pm2"
    "ts-node"
    "@nestjs/cli"
  )

  echo "**********"
  echo "Ubuntu installing OS packages"

  curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
  sudo apt update
  sudo apt install -y "${os_packages[@]}"

elif command -v pacman >/dev/null 2>&1; then
  os_packages=(
    "nodejs"
    "npm"
    "node-gyp"
  )
  node_packages=(
    "@mermaid-js/mermaid-cli"
    "@openai/codex"
    "neovim"
    "pm2"
    "semver"
    "ts-node"
    "yarn"
  )

  echo "**********"
  echo "Arch Linux installing OS packages"
  sudo pacman -Syu --noconfirm --needed "${os_packages[@]}"

else
  echo "No supported package manager found (apt or pacman)"
  exit 1
fi

# ------------------------------------------------------------------------------

echo "**********"
echo "Reinstalling global node packages"

sudo env "PATH=$PATH" npm install -g "${node_packages[@]}" \
  && echo "NodeJS packages installed." \
  || echo "Failed to install NodeJS packages."

echo "**********"
echo "Installed global packages:"
sudo env "PATH=$PATH" npm ls -g --depth=0 || true

echo "**********"
echo "Done!"
