#!/bin/bash

# ------------------------------------------------------------------------------
# Reset Node.js installation
# ------------------------------------------------------------------------------

echo "**********"
echo "Resetting Node.js installation"

if [[ -d /usr/lib/node_modules ]]; then
  echo "Removing /usr/lib/node_modules"
  sudo rm -rf /usr/lib/node_modules
else
  echo "/usr/lib/node_modules does not exist, skipping"
fi

# ------------------------------------------------------------------------------

if which apt &> /dev/null; then
  curl -fsSL https://deb.nodesource.com/setup_20.x | sudo -E bash -
  os_packages=(
    "nodejs"
    "yarn"
  )
  node_packages=(
    "@angular/cli"
    "neovim"
    "pm2"
    "ts-node"
    "@nestjs/cli"
  )

  echo "**********"
  echo "Ubuntu node install"
  sudo apt install -y "${os_packages[@]}"

elif which pacman &> /dev/null; then
  os_packages=(
    "nodejs"
    "npm"
    "node-gyp"
  )
  node_packages=(
    "@mermaid-js/mermaid-cli"
    "@openai/codex"
    "neovim"
    "node-gyp"
    "pm2"
    "semver"
    "ts-node"
    "yarn"
  )

  echo "**********"
  echo "Arch Linux reinstalling node packages"
  sudo pacman -Syu --noconfirm --needed "${os_packages[@]}"

else
  echo "No supported package manager found (apt or pacman)"
  exit 1
fi

# ------------------------------------------------------------------------------

for n in "${node_packages[@]}"; do
  echo "**********"
  echo "sudo npm install -g $n"
  sudo npm install -g "$n"
done

echo "**********"
echo "Done!"
