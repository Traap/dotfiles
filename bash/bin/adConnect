#!/usr/bin/env bash
# {{{ adConnect — Automatic AD reconnect + Passwordless Kerberos + SSSD check

set -euo pipefail

BINHOME="${BINHOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

# -------------------------------------------------------------------------- }}}
# {{{ Console output helpers
#
# Keep all script-generated status messages behind these helpers so noisy
# output is easy to identify and suppress when a caller needs silence.

green()  { printf "\033[1;32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[1;33m%s\033[0m\n" "$*"; }
red()    { printf "\033[1;31m%s\033[0m\n" "$*"; }

info()  { green  "[INFO]  $*"; }
warn()  { yellow "[WARN]  $*"; }
fail()  { red    "[FAIL]  $*"; }

# -------------------------------------------------------------------------- }}}
# {{{ Environment (from /etc/environment.d/27-Traap.conf)

: "${AD_DOMAIN:?AD_DOMAIN not set}"
: "${AD_DNS1:?AD_DNS1 not set}"

# -------------------------------------------------------------------------- }}}
# {{{ Runtime configuration
#
# These values describe the AD realm, network probes, local Kerberos files,
# reconnect cadence, and the state/lock files used to avoid repeated work.

AD_IDENTITY_TEST=true
AD_REALM="${AD_DOMAIN^^}"
AD_LOWER="${AD_DOMAIN,,}"
KEYTAB="$HOME/.config/krb5/user.keytab"
SSSD_LOOKUP_RETRIES="${SSSD_LOOKUP_RETRIES:-6}"
SSSD_LOOKUP_DELAY="${SSSD_LOOKUP_DELAY:-5}"
SYSTEM_KEYTAB="/etc/krb5.keytab"
AD_RECONNECT_AFTER_SECONDS="${AD_RECONNECT_AFTER_SECONDS:-86400}"
AD_CONNECT_STATE_DIR="${AD_CONNECT_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/adConnect}"
AD_CONNECT_STATE_FILE="${AD_CONNECT_STATE_FILE:-$AD_CONNECT_STATE_DIR/state}"
AD_CONNECT_LOCK="${AD_CONNECT_LOCK:-${XDG_RUNTIME_DIR:-/tmp}/adConnect.$UID.lock}"
AD_CONNECT_FORCE="${AD_CONNECT_FORCE:-false}"
AD_CONNECT_NETWORK_TIMEOUT="${AD_CONNECT_NETWORK_TIMEOUT:-0.25}"

if [[ ! "$AD_CONNECT_NETWORK_TIMEOUT" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    AD_CONNECT_NETWORK_TIMEOUT=0.25
fi

# -------------------------------------------------------------------------- }}}
# {{{ Detect AD network
#
# adConnect can be launched from generic network workflows, including networks
# that cannot reach AD.  In that case it is not an error and there is nothing
# useful to report, so exit silently before evaluating reconnect state or
# printing any informational messages.

ad_name_resolves() {
    if command -v timeout >/dev/null 2>&1; then
        timeout "$AD_CONNECT_NETWORK_TIMEOUT" getent hosts "$1" >/dev/null 2>&1
    else
        getent hosts "$1" >/dev/null 2>&1
    fi
}

ad_dns_reachable() {
    command -v timeout >/dev/null 2>&1 || return 1
    timeout "$AD_CONNECT_NETWORK_TIMEOUT" ping -n -c1 "$AD_DNS1" >/dev/null 2>&1
}

if ad_name_resolves "$AD_LOWER"; then
    AD_ONLINE=true
    info "AD network detected by DNS."
elif ad_name_resolves co.ventura.ca.us; then
    AD_ONLINE=true
    info "AD network detected by DNS."
elif ad_dns_reachable; then
    AD_ONLINE=true
    info "AD network detected by ping."
else
    exit 0
fi

# The remaining settings are only needed after AD is reachable.
: "${AD_USER:?AD_USER not set}"
: "${AD_DNS2:?AD_DNS2 not set}"
: "${WIN_DOMAIN:?WIN_DOMAIN not set}"

if [[ ! "$AD_RECONNECT_AFTER_SECONDS" =~ ^[0-9]+$ ]]; then
    warn "Invalid AD_RECONNECT_AFTER_SECONDS=$AD_RECONNECT_AFTER_SECONDS; using 86400."
    AD_RECONNECT_AFTER_SECONDS=86400
fi

# -------------------------------------------------------------------------- }}}
# {{{ Reconnect state
#
# A successful Kerberos reconnect writes a timestamp and boot ID.  This
# block reads that state, decides whether enough time or a reboot requires a
# new reconnect, and skips the rest of the script when the current ticket
# state is still fresh.

LAST_SUCCESS_EPOCH=0
LAST_BOOT_ID=""
CURRENT_BOOT_ID="$(cat /proc/sys/kernel/random/boot_id 2>/dev/null || printf unknown)"
NOW_EPOCH="$(date +%s)"

if [[ -r "$AD_CONNECT_STATE_FILE" ]]; then
    while IFS='=' read -r key value; do
        case "$key" in
            last_success_epoch)
                if [[ "$value" =~ ^[0-9]+$ ]]; then
                    LAST_SUCCESS_EPOCH="$value"
                fi
                ;;
            boot_id)
                LAST_BOOT_ID="$value"
                ;;
        esac
    done < "$AD_CONNECT_STATE_FILE"
fi

RECONNECT_REQUIRED=false
RECONNECT_REASON=""

if [[ "$AD_CONNECT_FORCE" == true || "$AD_CONNECT_FORCE" == 1 ]]; then
    RECONNECT_REQUIRED=true
    RECONNECT_REASON="forced"
elif (( LAST_SUCCESS_EPOCH == 0 )); then
    RECONNECT_REQUIRED=true
    RECONNECT_REASON="no previous successful reconnect"
elif [[ "$LAST_BOOT_ID" != "$CURRENT_BOOT_ID" ]]; then
    RECONNECT_REQUIRED=true
    RECONNECT_REASON="system reboot detected"
elif (( NOW_EPOCH - LAST_SUCCESS_EPOCH >= AD_RECONNECT_AFTER_SECONDS )); then
    RECONNECT_REQUIRED=true
    RECONNECT_REASON="last reconnect is at least 24 hours old"
elif (( NOW_EPOCH < LAST_SUCCESS_EPOCH )); then
    RECONNECT_REQUIRED=true
    RECONNECT_REASON="saved reconnect timestamp is in the future"
fi

if ! $RECONNECT_REQUIRED; then
    seconds_remaining=$((AD_RECONNECT_AFTER_SECONDS - (NOW_EPOCH - LAST_SUCCESS_EPOCH)))
    info "AD reconnect not required; next reconnect in ${seconds_remaining}s."
    exit 0
fi

info "AD reconnect required: $RECONNECT_REASON."

# -------------------------------------------------------------------------- }}}
# {{{ Single-run lock
#
# Multiple callers may invoke adConnect during login, VPN, or network
# changes.  The lock directory keeps those calls from prompting for Kerberos
# credentials or restarting services at the same time.

if ! mkdir "$AD_CONNECT_LOCK" 2>/dev/null; then
    warn "adConnect is already running: $AD_CONNECT_LOCK"
    exit 0
fi
trap 'rmdir "$AD_CONNECT_LOCK" 2>/dev/null || true' EXIT

# -------------------------------------------------------------------------- }}}
# {{{ SSSD health helpers
#
# These helpers keep host-domain-join checks, service status reporting, and
# related warnings close together.  User Kerberos can still work even when SSSD
# identity lookup is degraded, so failures here are warnings.

sssd_available() {
    command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files sssd.service >/dev/null 2>&1
}

check_sssd_keytab() {
    if [[ ! -e "$SYSTEM_KEYTAB" ]]; then
        warn "SSSD system keytab is missing: $SYSTEM_KEYTAB"
        warn "User kinit can still work, but SSSD AD identity lookups need a host keytab from a domain join."
        return 1
    fi

    if [[ ! -r "$SYSTEM_KEYTAB" ]]; then
        warn "SSSD system keytab exists but is not readable by this user: $SYSTEM_KEYTAB"
        return 0
    fi

    if command -v klist >/dev/null 2>&1 && ! klist -k "$SYSTEM_KEYTAB" >/dev/null 2>&1; then
        warn "SSSD system keytab exists but klist cannot read usable entries from it: $SYSTEM_KEYTAB"
        return 1
    fi

    return 0
}

report_sssd_state() {
    if ! sssd_available; then
        warn "sssd.service is not installed or not known to systemd."
        return 1
    fi

    if systemctl is-active --quiet sssd; then
        info "sssd.service is active."
        return 0
    fi

    warn "sssd.service is not active; identity lookup is expected to fail."
    systemctl --no-pager --plain status sssd 2>/dev/null | sed -n '1,8p' || true
    return 1
}

# -------------------------------------------------------------------------- }}}
# {{{ DNS configuration (only when online)
# Prefer eth0 when available, otherwise fall back to wlan0

if $AD_IDENTITY_TEST; then
  if $AD_ONLINE; then
      iface=""
      if ip link show eth0 >/dev/null 2>&1; then
          iface="eth0"
      elif ip link show wlan0 >/dev/null 2>&1; then
          iface="wlan0"
      else
          warn "No eth0/wlan0 interface found — skipping resolvectl DNS config."
          iface=""
      fi

      if [[ -n "$iface" ]]; then
          info "Applying AD DNS configuration on $iface..."
          sudo resolvectl dns "$iface" "$AD_DNS1" "$AD_DNS2" || true
          sudo resolvectl domain "$iface" "$AD_LOWER" co.ventura.ca.us || true

          if sssd_available; then
              check_sssd_keytab || true
              info "Restarting SSSD after DNS update..."
              sudo systemctl restart sssd || warn "Unable to restart SSSD; identity lookup may need more time."
              report_sssd_state || true
          fi
      fi
  fi
fi

# -------------------------------------------------------------------------- }}}
# {{{ Kerberos login
#
# Prompt for or refresh the user's AD Kerberos ticket.  The reconnect state
# is updated only when this succeeds.

info "Running kinit for $AD_USER@$AD_REALM..."
if kinit "$AD_USER@$AD_REALM"; then
    KINIT_OK=true
    info "Kerberos ticket acquired."
else
    KINIT_OK=false
    warn "Kerberos login failed."
fi

# -------------------------------------------------------------------------- }}}
# {{{ Kerberos ticket check
#
# Show the resulting ticket cache after kinit so an interactive user can
# confirm what principal and expiry are active.

info "Current Kerberos tickets:"
klist || warn "No active Kerberos tickets."

# -------------------------------------------------------------------------- }}}
# {{{ Mount network drives
#
# On the known bare-metal host, reconnect the expected SMB drive letters
# after AD credentials have been refreshed.


if "$BINHOME"/is_bare_metal; then
  if "$BINHOME"/hostName "GSA-M98AXA"; then
     "$BINHOME"/mountUp i
     "$BINHOME"/mountUp h
     "$BINHOME"/mountUp o
     "$BINHOME"/mountUp s
  fi
fi

# -------------------------------------------------------------------------- }}}
# {{{ AD identity resolution test
#
# Confirm that NSS can ask SSSD for AD identities and that SSSD can resolve
# the configured user.  This catches domain-join and service-start problems
# that Kerberos alone does not prove.


if $AD_IDENTITY_TEST; then
  if ! awk '
      $1 == "passwd:" {
          for (i = 2; i <= NF; i++) {
              if ($i == "sss") {
                  found = 1
              }
          }
      }
      END { exit found ? 0 : 1 }
  ' /etc/nsswitch.conf; then
      warn "NSS passwd lookups do not include sss; getent cannot query SSSD."
      warn "Add sss to the passwd/group lines in /etc/nsswitch.conf, then restart SSSD."
  else
      check_sssd_keytab || true
      report_sssd_state || true

      info "Checking SSSD identity for $AD_USER..."
      sssd_identity_found=false
      sssd_identity_candidates=(
          "$WIN_DOMAIN\\$AD_USER"
          "${WIN_DOMAIN,,}\\$AD_USER"
          "$AD_USER@$AD_LOWER"
          "$AD_USER@$AD_REALM"
          "$AD_USER"
      )

      for ((attempt = 1; attempt <= SSSD_LOOKUP_RETRIES; attempt++)); do
          for sssd_identity in "${sssd_identity_candidates[@]}"; do
              if timeout 5 getent passwd "$sssd_identity" >/dev/null 2>&1; then
                  info "SSSD successfully resolved AD user as $sssd_identity."
                  sssd_identity_found=true
                  break 2
              fi
          done

          if (( attempt < SSSD_LOOKUP_RETRIES )); then
              info "SSSD identity lookup not ready; retrying in ${SSSD_LOOKUP_DELAY}s..."
              sleep "$SSSD_LOOKUP_DELAY"
          fi
      done

      if ! $sssd_identity_found; then
          warn "SSSD identity lookup failed; tried: ${sssd_identity_candidates[*]}"
          warn "SSSD may be offline, misconfigured, or unable to reach AD after reboot."
      fi
  fi
fi

# -------------------------------------------------------------------------- }}}
# {{{ Persist successful reconnect state
#
# Store the timestamp and boot ID only after Kerberos succeeds.  A failed
# login leaves the previous state intact so the next AD-network run can try
# again.

if $KINIT_OK; then
    mkdir -p "$AD_CONNECT_STATE_DIR"
    state_tmp="$AD_CONNECT_STATE_FILE.$$"
    {
        printf 'last_success_epoch=%s\n' "$NOW_EPOCH"
        printf 'boot_id=%s\n' "$CURRENT_BOOT_ID"
    } > "$state_tmp"
    mv "$state_tmp" "$AD_CONNECT_STATE_FILE"
    info "Recorded successful AD reconnect state."
else
    warn "AD reconnect state was not updated because Kerberos login failed."
fi

info "adConnect complete."

# -------------------------------------------------------------------------- }}}
