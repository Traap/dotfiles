#!/usr/bin/env bash
# {{{ vpnConnect - start snx-rs and run adConnect after tunnel readiness

set -euo pipefail

BINHOME="${BINHOME:-$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)}"

# -------------------------------------------------------------------------- }}}
# {{{ Runtime configuration

SNX_CONFIG="${SNX_CONFIG:-/etc/snx-rs/config.toml}"
SNX_IKE_PERSIST="${SNX_IKE_PERSIST:-false}"
SNX_READY_PATTERN="${SNX_READY_PATTERN:-Tunnel connected}"
SNX_USER="${SNX_USER:-${AD_USER:-}}"
VPN_CONNECT_AD_FORCE="${VPN_CONNECT_AD_FORCE:-false}"

# -------------------------------------------------------------------------- }}}
# {{{ Console output helpers

green()  { printf "\033[1;32m%s\033[0m\n" "$*"; }
yellow() { printf "\033[1;33m%s\033[0m\n" "$*"; }
red()    { printf "\033[1;31m%s\033[0m\n" "$*"; }

info()  { green  "[INFO]  $*"; }
warn()  { yellow "[WARN]  $*"; }
fail()  { red    "[FAIL]  $*"; }

# -------------------------------------------------------------------------- }}}
# {{{ User documentation

print_help() {
  cat <<'HELP'
vpnConnect - start an snx-rs VPN tunnel and run adConnect when it is ready

Usage:
  vpnConnect
  vpnConnect --help

Behavior:
  - Prompts for a VPN password on the controlling terminal unless a password
    source is provided through the environment.
  - Starts snx-rs in the background and streams its log output.
  - Waits for the tunnel-ready log line before launching adConnect.
  - Calls adConnect with AD_CONNECT_CONFIGURE_DNS=false so the established VPN
    tunnel's DNS and routing are not rewritten during the post-connect hook.
  - Leaves the VPN process running until snx-rs exits or vpnConnect receives a
    signal that triggers cleanup.

Required commands:
  snx-rs
  sudo
  base64
  tail

Optional environment:
  SNX_CONFIG=/etc/snx-rs/config.toml
      snx-rs configuration file.

  SNX_IKE_PERSIST=false
      Value passed to snx-rs --ike-persist.

  SNX_READY_PATTERN="Tunnel connected"
      Log text that indicates the VPN tunnel is ready for adConnect.

  SNX_USER=$AD_USER
      VPN user name passed to snx-rs --user-name when non-empty.

  SNX_PASSWORD_B64
      Base64-encoded VPN password.  When set, no password prompt is shown.

  SNX_PASSWORD_CMD
      Shell command that prints the raw VPN password.  Its output is base64
      encoded before being passed to snx-rs.

  VPN_CONNECT_AD_FORCE=false
      Set true to pass AD_CONNECT_FORCE=true to adConnect after the tunnel is
      ready.  The default lets adConnect skip work when its saved state is
      still fresh.

Exit status:
  Returns the snx-rs process exit status after log streaming completes.
HELP
}

case "${1:-}" in
  -h|--help)
    print_help
    exit 0
    ;;
  "")
    ;;
  *)
    fail "Unknown argument: $1"
    printf 'Usage: vpnConnect [--help]\n' >&2
    exit 2
    ;;
esac

# -------------------------------------------------------------------------- }}}
# {{{ Dependency validation

if ! command -v snx-rs >/dev/null 2>&1; then
  fail "snx-rs is not installed or not on PATH." >&2
  exit 127
fi

# -------------------------------------------------------------------------- }}}
# {{{ Post-connect AD hook

run_ad_connect() {
  if [[ -x "$BINHOME/adConnect" ]]; then
    info "Starting adConnect after VPN tunnel connected."
    AD_CONNECT_FORCE="$VPN_CONNECT_AD_FORCE" AD_CONNECT_CONFIGURE_DNS=false "$BINHOME/adConnect" </dev/tty >/dev/tty 2>&1
  else
    warn "adConnect is not executable: $BINHOME/adConnect"
  fi
}

# -------------------------------------------------------------------------- }}}
# {{{ Cleanup

cleanup() {
  if [[ -n "${SNX_PID:-}" ]] && kill -0 "$SNX_PID" 2>/dev/null; then
    kill "$SNX_PID" 2>/dev/null || true
    wait "$SNX_PID" 2>/dev/null || true
  fi

  if [[ -n "${SNX_LOG:-}" && -e "$SNX_LOG" ]]; then
    rm -f "$SNX_LOG"
  fi
}

# -------------------------------------------------------------------------- }}}
# {{{ Password helpers

encode_base64() {
  base64 | tr -d '\n'
}

read_snx_password() {
  local password

  if [[ -n "${SNX_PASSWORD_B64:-}" ]]; then
    printf '%s' "$SNX_PASSWORD_B64"
    return
  fi

  if [[ -n "${SNX_PASSWORD_CMD:-}" ]]; then
    "$SHELL" -c "$SNX_PASSWORD_CMD" | encode_base64
    return
  fi

  printf 'VPN password' >/dev/tty
  if [[ -n "$SNX_USER" ]]; then
    printf ' for %s' "$SNX_USER" >/dev/tty
  fi
  printf ': ' >/dev/tty
  IFS= read -r -s password </dev/tty
  printf '\n' >/dev/tty
  printf '%s' "$password" | encode_base64
}

# -------------------------------------------------------------------------- }}}
# {{{ Start VPN and stream logs

trap cleanup EXIT

if [[ ! -r /dev/tty ]]; then
  fail "No attached TTY to get user input." >&2
  exit 1
fi

SNX_LOG="$(mktemp "${TMPDIR:-/tmp}/vpnConnect.snx-rs.XXXXXX")"

info "Starting snx-rs with ike-persist=$SNX_IKE_PERSIST."
sudo -v

snx_args=(
  -c "$SNX_CONFIG"
  --ike-persist "$SNX_IKE_PERSIST"
  --password "$(read_snx_password)"
)

if [[ -n "$SNX_USER" ]]; then
  snx_args+=(--user-name "$SNX_USER")
fi

sudo -n snx-rs "${snx_args[@]}" >"$SNX_LOG" 2>&1 &
SNX_PID=$!
ad_connect_started=false

tail -n +1 -F --pid="$SNX_PID" "$SNX_LOG" 2>/dev/null | while IFS= read -r line; do
  line="${line//$'\r'/}"
  printf '%s\n' "$line"

  if ! $ad_connect_started && [[ "$line" == *"$SNX_READY_PATTERN"* ]]; then
    ad_connect_started=true
    run_ad_connect || warn "adConnect failed; leaving VPN tunnel running." >&2
  fi
done

wait "$SNX_PID"

# -------------------------------------------------------------------------- }}}
