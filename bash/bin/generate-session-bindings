#!/usr/bin/env bash

set -euo pipefail

if [[ -z ${SESSION_BINDINGS_HOME:-} ]]; then
  printf 'WARNING: SESSION_BINDINGS_HOME is not defined; no bindings were generated.\n' >&2
  exit 1
fi

SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
SOURCE_FILE=$SESSION_BINDINGS_HOME/sessions.tsv
TEMP_DIR=$(mktemp -d)

trap 'rm -rf -- "$TEMP_DIR"' EXIT

OUTPUT_DIR=$SESSION_BINDINGS_HOME

BASH_OUTPUT=$TEMP_DIR/bash
TMUX_OUTPUT=$TEMP_DIR/tmux.conf
HYPR_OUTPUT=$TEMP_DIR/hypr.lua

declare -a KEYS=()
declare -a SESSIONS=()
declare -A SEEN_KEYS=()
declare -A SEEN_SESSIONS=()

while IFS=$'\t' read -r key session extra; do
  [[ -z $key || $key == \#* ]] && continue

  if [[ -n ${extra:-} || ! $key =~ ^[a-z]$ || ! $session =~ ^[A-Za-z][A-Za-z0-9_-]*$ ]]; then
    printf 'Invalid session binding: key=%q session=%q extra=%q\n' \
      "$key" "$session" "${extra:-}" >&2
    exit 1
  fi

  if [[ -n ${SEEN_KEYS[$key]:-} || -n ${SEEN_SESSIONS[$session]:-} ]]; then
    printf 'Duplicate session binding: key=%q session=%q\n' "$key" "$session" >&2
    exit 1
  fi

  KEYS+=("$key")
  SESSIONS+=("$session")
  SEEN_KEYS[$key]=1
  SEEN_SESSIONS[$session]=1
done < "$SOURCE_FILE"

if (( ${#KEYS[@]} == 0 )); then
  printf 'No session bindings found in %s\n' "$SOURCE_FILE" >&2
  exit 1
fi

{
  printf '%s\n' \
    '# Generated by bindings/generate-session-bindings; do not edit.' \
    '' \
    'if [[ -z ${SESSION_BINDINGS_HOME:-} ]]; then' \
    '  printf '\''WARNING: SESSION_BINDINGS_HOME is not defined.\n'\'' >&2' \
    'fi' \
    '' \
    'if [[ -n ${WSL_DISTRO_NAME:-} && -z ${HYPRLAND_INSTANCE_SIGNATURE:-} ]]; then'

  for index in "${!KEYS[@]}"; do
    printf '  bind -x '\''"\\e%s":"ao %s"'\''\n' \
      "${KEYS[$index]}" "${SESSIONS[$index]}"
  done

  printf '\n'

  for index in "${!KEYS[@]}"; do
    printf '  bind -x '\''"\\e%s":"tmux kill-session -t %s"'\''\n' \
      "${KEYS[$index]^^}" "${SESSIONS[$index]}"
  done

  printf '%s\n' 'fi'
} > "$BASH_OUTPUT"

{
  printf '%s\n' \
    '# Generated by bindings/generate-session-bindings; do not edit.' \
    '' \
    'if-shell '\''[ -z "$SESSION_BINDINGS_HOME" ]'\'' \' \
    '  '\''display-message "WARNING: SESSION_BINDINGS_HOME is not defined."'\''' \
    '' \
    'set-environment -g HYPRLAND_INSTANCE_SIGNATURE "$HYPRLAND_INSTANCE_SIGNATURE"' \
    '' \
    'if-shell '\''[ -z "$HYPRLAND_INSTANCE_SIGNATURE" ]'\'' {' \
    '  # Alt-lowercase → launch or attach.'

  for index in "${!KEYS[@]}"; do
    printf '  bind-key -n M-%s run-shell "ao %s"\n' \
      "${KEYS[$index]}" "${SESSIONS[$index]}"
  done

  printf '%s\n' '' '  # Alt-uppercase → kill.'

  for index in "${!KEYS[@]}"; do
    printf '  bind-key -n M-%s kill-session -t %s\n' \
      "${KEYS[$index]^^}" "${SESSIONS[$index]}"
  done

  printf '%s\n' '}'
} > "$TMUX_OUTPUT"

{
  printf '%s\n' \
    '-- Generated by bindings/generate-session-bindings; do not edit.' \
    '' \
    'if not os.getenv("SESSION_BINDINGS_HOME") then' \
    '  print("WARNING: SESSION_BINDINGS_HOME is not defined.")' \
    'end' \
    '' \
    'local vars = require("hypr.vars")' \
    '' \
    'local sessions = {'

  for index in "${!KEYS[@]}"; do
    printf '  { key = "%s", name = "%s" },\n' \
      "${KEYS[$index]^^}" "${SESSIONS[$index]}"
  done

  printf '%s\n' \
    '}' \
    '' \
    'for _, session in ipairs(sessions) do' \
    '  local toggle_keys = "ALT + " .. session.key' \
    '  local kill_keys = "ALT + SHIFT + " .. session.key' \
    '' \
    '  hl.unbind(toggle_keys)' \
    '  o.bind(' \
    '    toggle_keys,' \
    '    "Toggle " .. session.name,' \
    '    vars.bin_home .. "/toggler " .. session.name' \
    '  )' \
    '' \
    '  hl.unbind(kill_keys)' \
    '  o.bind(' \
    '    kill_keys,' \
    '    "Kill " .. session.name,' \
    '    "tmux kill-session -t " .. session.name' \
    '  )' \
    'end'
} > "$HYPR_OUTPUT"

MODE=${1:-generate}
if [[ $MODE != generate && $MODE != --check ]]; then
  printf 'Usage: %s [--check]\n' "$0" >&2
  exit 1
fi

if [[ $MODE == --check ]]; then
  cmp --silent "$BASH_OUTPUT" "$OUTPUT_DIR/bash"
  cmp --silent "$TMUX_OUTPUT" "$OUTPUT_DIR/tmux.conf"
  cmp --silent "$HYPR_OUTPUT" "$OUTPUT_DIR/hypr.lua"
else
  mkdir -p "$OUTPUT_DIR"
  cp -- "$BASH_OUTPUT" "$OUTPUT_DIR/bash"
  cp -- "$TMUX_OUTPUT" "$OUTPUT_DIR/tmux.conf"
  cp -- "$HYPR_OUTPUT" "$OUTPUT_DIR/hypr.lua"
fi
